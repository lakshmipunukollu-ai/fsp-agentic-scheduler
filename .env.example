# ── Application ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Authentication ─────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fsp_scheduler
# Or individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fsp_scheduler
# DB_USER=postgres
# DB_PASSWORD=postgres

# ── AI (Anthropic Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Twilio SMS Notifications ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Optional: comma-separated E.164 numbers alerted when a student submits a schedule (in addition to users.phone on admin/scheduler accounts)
# TWILIO_STAFF_NOTIFY_NUMBERS=+15551234567,+15559876543
# Test SMS from backend: npm run test:sms -- +15551234567  (trial: verify destination in Twilio first)
# TEST_SMS_TO=+15551234567 npm run test:sms
# Leave Twilio vars empty to run in demo mode (SMS logged but not sent)

# ── Email (optional — approval notifications via nodemailer) ─────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
# Test real SMTP: cd backend && npm run test:email -- you@example.com
# Test without Gmail (Ethereal preview URL): cd backend && npm run test:email:demo
# While iterating: log SMS/email to the API terminal only (no Twilio/SMTP sends)
# NOTIFICATIONS_LOG_ONLY=true

# ── Weather (OpenWeatherMap) ───────────────────────────────────
OPENWEATHER_API_KEY=
# Free tier at openweathermap.org — required for live weather constraints

# ── FSP API Integration ────────────────────────────────────────
FSP_API_MODE=mock
# Set to 'live' when you have real FSP API credentials:
# FSP_API_BASE_URL=https://api.flightschedulepro.com
# FSP_API_TOKEN=

# ── Frontend ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5001
# Optional: login hero background MP4 URL (defaults to free Pexels CDN if unset)
# VITE_LOGIN_HERO_VIDEO_URL=/login-hero.mp4

